# Local defaults
DRAWIO_BASE_URL=http://localhost:8080/
DRAWIO_OUTPUT_DIR=./diagrams
MCP_PORT=3001
MCP_LISTEN=127.0.0.1

# Docker Compose host bindings
DRAWIO_HOST=127.0.0.1
DRAWIO_HTTP_PORT=8080
DRAWIO_HTTPS_PORT=8443
MCP_HOST=127.0.0.1

# Docker container paths
DOCKER_DRAWIO_OUTPUT_DIR=/data/diagrams
DOCKER_MCP_LISTEN=0.0.0.0
DOCKER_VIEWER_PATH=/app/viewer

# Set this when binding outside localhost or deploying remotely.
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional hosted widget origin, for example https://mcp.example.com
# DOMAIN=

# Optional override for browser launching. Defaults are HTTP: off, stdio: on.
# OPEN_BROWSER=0

# Optional override. By default the repo vendored viewer is used locally.
# VIEWER_PATH=

# Hosted platforms such as Railway or Render usually inject PORT.
# Leave MCP_PORT unset in that environment if you want the server to use PORT.
# PORT=3001
